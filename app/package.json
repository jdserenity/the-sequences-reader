{
  "name": "the-sequences-reader",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "d1:migrate:local": "wrangler d1 migrations apply sequences-reader-progress --local",
    "d1:migrate:remote": "wrangler d1 migrations apply sequences-reader-progress --remote",
    "seed:push": "node scripts/push-seed-progress.mjs",
    "seed:d1": "node scripts/build-seed-sql.mjs && wrangler d1 execute sequences-reader-progress --remote --file=scripts/seed-through-doublethink.sql"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.0.0",
    "@sveltejs/kit": "^2.21.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "happy-dom": "^20.10.6",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "marked": "^15.0.0"
  }
}
